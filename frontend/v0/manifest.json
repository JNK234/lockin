{
    "manifest_version": 3,
    "name": "LockIn",
    "version": "1.0",
    "description": "Focus. Track. Achieve.",
    "permissions": [
        "tabs",
        "storage",
        "scripting",
        "notifications",
        "alarms"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html"
    }
}