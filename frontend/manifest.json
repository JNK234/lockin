{
    "manifest_version": 3,
    "description": "Stay focused. LockIn tracks your browsing, nudges you when distracted, and shows a focus report.",
    "name": "LockIn",
    "version": "1.0",
    "permissions": [
        "tabs",
        "storage",
        "scripting",
        "alarms"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "overlay.js"
            ]
        }
    ]
}