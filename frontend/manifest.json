{
    "manifest_version": 3,
    "description": "Anchors browser activity to a specific task for GraphRAG.",
    "name": "Context Anchor",
    "version": "1.0",
    "permissions": [
        "tabs",
        "storage",
        "scripting",
        "alarms"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "overlay.js"
            ]
        }
    ]
}